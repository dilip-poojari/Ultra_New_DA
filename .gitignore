# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore kubeconfig files
.kube/
*.kubeconfig

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore backup files
*.backup
*.bak

# Ignore log files
*.log

# Ignore temporary files
tmp/
temp/
*.tmp

# Ignore build artifacts
dist/
build/
*.tgz
*.tar.gz

# Ignore sensitive files
secrets/
*.pem
*.key
*.crt